---
import { ssr } from "fse-ssr/ssr";
import Input from "../components/Input.astro";
import Layout from "../layouts/Layout.astro";

const { t, error, success } = ssr<{ error?: string; success?: string }>();
const errorLogin = t.login as Record<string, string>;
const errors = t.errors as Record<string, string>;
const messages = t.messages as Record<string, string>;
---

<Layout title={t.login.title} sidebar={false}>
  <main class="min-h-screen w-full grid place-items-center bg-secondary-50 px-4 py-12">
    <div class="w-full max-w-sm">
      <!-- Logo -->
      <div class="flex justify-center mb-8">
        <a href="/">
          <span class="text-2xl font-extrabold">⌂</span>
        </a>
      </div>

      <!-- Card -->
      <div class="bg-white border border-secondary-200 rounded-xl overflow-hidden">
        <div class="px-6 pt-6 pb-2">
          <h1 class="text-lg font-semibold text-secondary-900 mb-1">
            {t.login.title}
          </h1>
        </div>

        <form action="/login" method="POST" data-astro-reload>
          <div class="px-6 py-4 flex flex-col gap-4">
            <Input
              id="email"
              type="email"
              placeholder={t.login.email}
              required={true}
            />
            <Input
              id="password"
              type="password"
              placeholder={t.login.password}
              required={true}
            />
            <div class="flex justify-end -mt-1">
              <a href="/forgot-password" class="text-xs text-secondary-500 hover:text-primary-600 hover:underline transition-colors">
                {t.login.forgot_password}
              </a>
            </div>
          </div>

          <div class="px-6 pb-5">
            <button
              class="btn-primary w-full h-10 disabled:cursor-not-allowed disabled:opacity-50"
            >
              <span>{t.login.submit}</span>
            </button>
          </div>

          {error && (
            <div class="px-6 pb-4">
              <div class="w-full px-4 py-3 text-sm text-red-600 border border-red-200 rounded-lg bg-red-50" role="alert">
                <p>{errors[error] ?? errorLogin[error] ?? error}</p>
              </div>
            </div>
          )}

          {success && (
            <div class="px-6 pb-4">
              <div class="w-full px-4 py-3 text-sm text-primary-700 border border-primary-200 rounded-lg bg-primary-50" role="alert">
                <p>{messages[success] ?? success}</p>
              </div>
            </div>
          )}
        </form>

        <div class="px-6 py-4 border-t border-secondary-100 text-center">
          <p class="text-sm text-secondary-500">
            {t.login.no_account}
            <a href="/register" class="text-primary-600 hover:text-primary-700 font-medium hover:underline ml-1">
              {t.login.register}
            </a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
