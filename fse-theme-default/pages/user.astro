---
import { ssr } from "fse-ssr/ssr";
import Card from "../components/Card.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import type { UserPage } from "../types/pages";

const { t, id, email, role, roles } = ssr<UserPage>();
const roleLabels = t.roles as Record<string, string>;
---

<Layout title={t.users.edit}>
  <main class="max-w-2xl mx-auto w-full">
    <Header backlink="/users">{t.users.edit_title}</Header>
    <Card>
      <form action={`/users/${id}`} method="POST" data-astro-reload class="flex flex-col gap-6">
        <!-- Email (read-only) -->
        <div>
          <label class="block text-sm font-medium text-secondary-700 mb-2">
            {t.users.email}
          </label>
          <div class="px-4 py-2.5 rounded-lg bg-secondary-50 border border-secondary-100">
            <span class="text-sm font-medium text-secondary-900">
              {email}
            </span>
          </div>
        </div>

        <!-- Role -->
        <div class="relative w-full">
          <select
            id="role"
            name="role"
            required
            class="relative w-full h-10 px-3.5 text-sm transition-all bg-white border border-secondary-300 rounded-lg outline-hidden appearance-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 peer text-secondary-900"
          >
            {
              roles.map((r) => (
                <option value={r.value} selected={r.value === role}>
                  {roleLabels[r.value] ?? r.label}
                </option>
              ))
            }
          </select>
          <label
            for="role"
            class="pointer-events-none absolute top-2.5 left-2 z-1 px-1.5 text-sm text-secondary-500 transition-all before:absolute before:top-0 before:left-0 before:z-[-1] before:block before:h-full before:w-full before:bg-white before:transition-all peer-valid:-top-2 peer-valid:text-xs peer-focus:-top-2 peer-focus:text-xs peer-focus:text-primary-600"
          >
            {t.users.role}
          </label>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-secondary-400">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </div>

        <!-- Actions -->
        <div class="flex sm:justify-end pt-5 border-t border-secondary-100">
          <button type="submit" class="btn-primary w-full sm:w-auto">
            <span>{t.common.save}</span>
          </button>
        </div>
      </form>
    </Card>
  </main>
</Layout>
