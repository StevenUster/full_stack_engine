---
import { ssr } from "fse-ssr/ssr";
import EmailLayout from "../../layouts/EmailLayout.astro";

const { t, verify_url } = ssr<{ verify_url: string }>();
---

<EmailLayout title={t.verify_email.subject}>
  <h1 slot="header" style="margin: 0; color: #ffffff; font-size: 20px; font-weight: 600; letter-spacing: 0.025em;">
    {t.verify_email.header}
  </h1>

  <p style="margin: 0; margin-bottom: 20px; color: #231f16; font-size: 16px; line-height: 1.625;">
    {t.verify_email.body}
  </p>

  <div style="text-align: center; padding-top: 12px; padding-bottom: 28px;">
    <a
      href={verify_url}
      target="_blank"
      style="display: inline-block; padding: 14px 36px; background-color: #6a9b3c; color: #ffffff; text-decoration: none; font-size: 14px; font-weight: 600; border-radius: 6px; letter-spacing: 0.025em;"
    >
      {t.verify_email.cta}
    </a>
  </div>

  <p style="margin: 0; margin-bottom: 12px; color: #655650; font-size: 14px; line-height: 1.5;">
    {t.verify_email.fallback}
  </p>
  <p style="margin: 0; word-break: break-all;">
    <a href={verify_url} style="color: #6a9b3c; font-size: 12px; text-decoration: underline;">
      {verify_url}
    </a>
  </p>

  <p slot="footer" style="margin: 0; color: #655650; font-size: 12px; line-height: 1.625;">
    {t.verify_email.footer}
  </p>
</EmailLayout>
