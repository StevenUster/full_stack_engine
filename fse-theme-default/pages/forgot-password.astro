---
import { ssr } from "fse-ssr/ssr";
import Input from "../components/Input.astro";
import Layout from "../layouts/Layout.astro";

const { t, error, success } = ssr<{ error?: string; success?: string }>();
const errors = t.errors as Record<string, string>;
const messages = t.messages as Record<string, string>;
---

<Layout title={t.forgot_password.title} sidebar={false}>
  <main class="min-h-screen w-full grid place-items-center bg-secondary-50 px-4 py-12">
    <div class="w-full max-w-sm">
      <div class="flex justify-center mb-8">
        <a href="/">
          <span class="text-2xl font-extrabold">⌂</span>
        </a>
      </div>

      <div class="bg-white border border-secondary-200 rounded-xl overflow-hidden">
        <div class="px-6 pt-6 pb-2">
          <h1 class="text-lg font-semibold text-secondary-900 mb-1">
            {t.forgot_password.title}
          </h1>
          <p class="text-sm text-secondary-500">
            {t.forgot_password.description}
          </p>
        </div>

        <form action="/forgot-password" method="POST" data-astro-reload>
          <div class="px-6 py-4">
            <Input id="email" type="email" placeholder={t.forgot_password.email} required={true} />
          </div>

          <div class="px-6 pb-5">
            <button class="btn-primary w-full h-10 disabled:cursor-not-allowed disabled:opacity-50">
              <span>{t.forgot_password.submit}</span>
            </button>
          </div>

          {error && (
            <div class="px-6 pb-4">
              <div class="w-full px-4 py-3 text-sm text-red-600 border border-red-200 rounded-lg bg-red-50" role="alert">
                <p>{errors[error] ?? error}</p>
              </div>
            </div>
          )}

          {success && (
            <div class="px-6 pb-4">
              <div class="w-full px-4 py-3 text-sm text-primary-700 border border-primary-200 rounded-lg bg-primary-50" role="alert">
                <p>{messages[success] ?? success}</p>
              </div>
            </div>
          )}
        </form>

        <div class="px-6 py-4 border-t border-secondary-100 text-center">
          <a href="/login" class="text-sm text-primary-600 hover:text-primary-700 hover:underline font-medium">
            {t.forgot_password.back_to_login}
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
