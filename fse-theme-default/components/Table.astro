---
import { ssr } from "fse-ssr/ssr";
import type { SsrList } from "fse-ssr/ssr";
import type { TableHeader } from "../types/pages";
import Modal from "./Modal.astro";

interface Props {
  /** Column config; page-static, so branching on `format` happens at build time. */
  headers: TableHeader[];
  /** Server-side rows; each column renders `row[header.key]`. */
  rows: SsrList<any>;
}

const { headers, rows } = Astro.props;
const { t } = ssr();
// Locale lookup with an SSR value as the key (e.g. the row's role).
const roleLabels = t.roles as Record<string, string>;

// Unique per Table instance so multiple tables on one page don't collide on
// the shared delete-confirmation dialog.
const modalId = `table-delete-modal-${crypto.randomUUID()}`;
---

<div class="w-full overflow-x-auto">
  <table class="w-full text-left border-collapse" cellspacing="0">
    <thead class="hidden md:table-header-group">
      <tr class="bg-secondary-50">
        {
          headers.map((h) => (
            <th
              scope="col"
              class="h-11 px-4 text-xs font-semibold uppercase tracking-wide border-b border-secondary-200 text-secondary-500"
            >
              {h.title}
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr class="flex flex-col md:table-row transition-colors hover:bg-secondary-50 border-b border-secondary-100 last:border-b-0 p-4 md:p-0 gap-1.5 md:gap-0">
            {headers.map((h) => (
              <td class="text-sm md:border-t border-secondary-100 relative">
                {h.format === "number" ? (
                  <div class="px-4 py-2.5 flex items-center justify-between md:justify-start gap-4">
                    <span class="md:hidden text-xs font-medium text-secondary-400 uppercase tracking-wide">
                      {h.title}
                    </span>
                    <input
                      type="number"
                      value={row[h.key]}
                      class="w-16 px-2.5 py-1.5 text-sm border border-secondary-300 rounded-lg focus:border-primary-500 focus:ring-1 focus:ring-primary-500 focus:outline-hidden"
                    />
                  </div>
                ) : h.format === "delete" ? (
                  <div class="px-4 py-2.5 flex items-center justify-between md:justify-start gap-4">
                    <span class="md:hidden text-xs font-medium text-secondary-400 uppercase tracking-wide">
                      {h.title}
                    </span>
                    <button
                      type="button"
                      class="p-1.5 text-secondary-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors table-delete-trigger"
                      data-modal-id={modalId}
                      data-url={row.delete_url}
                      data-error-msg={t.table.delete_error ?? "Error occurred"}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6" />
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                        <path d="M10 11v6m4-6v6" />
                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                      </svg>
                    </button>
                  </div>
                ) : (
                  <a
                    href={row.link}
                    class="px-4 py-2.5 flex items-center justify-between md:justify-start gap-4 h-full text-secondary-800 hover:text-secondary-900"
                  >
                    <span class="md:hidden text-xs font-medium text-secondary-400 uppercase tracking-wide">
                      {h.title}
                    </span>
                    <div class="flex-1 md:flex-none text-right md:text-left">
                      {h.format === "image" ? (
                        row[h.key] ? (
                          <img
                            src={row[h.key]}
                            alt="Thumbnail"
                            class="w-10 h-10 object-cover rounded-lg ml-auto md:ml-0"
                          />
                        ) : (
                          <div class="w-10 h-10 bg-secondary-100 rounded-lg flex items-center justify-center text-secondary-400 text-xs ml-auto md:ml-0">
                            —
                          </div>
                        )
                      ) : h.key === "role" ? (
                        roleLabels[row[h.key]] ?? row[h.key]
                      ) : (
                        row[h.key]
                      )}
                    </div>
                  </a>
                )}
              </td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<!-- Shared delete-confirmation dialog; each delete button fills in its target. -->
<Modal id={modalId} title={t.table.delete_title}>
  <p class="text-sm text-secondary-600 mb-5">{t.table.delete_confirm}</p>
  <div class="flex justify-end gap-2">
    <button type="button" class="btn-secondary modal-close-btn" data-modal-id={modalId}>
      {t.table.cancel}
    </button>
    <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors table-delete-confirm">
      {t.table.delete_btn}
    </button>
  </div>
</Modal>

<script>
  // Opening/closing and backdrop dismissal are handled globally by Modal.astro.
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;

    const trigger = target.closest(".table-delete-trigger");
    if (trigger) {
      const modalId = trigger.getAttribute("data-modal-id");
      const modal = modalId ? (document.getElementById(modalId) as HTMLDialogElement | null) : null;
      if (modal) {
        const confirmBtn = modal.querySelector(".table-delete-confirm");
        confirmBtn?.setAttribute("data-url", trigger.getAttribute("data-url") || "");
        confirmBtn?.setAttribute("data-error-msg", trigger.getAttribute("data-error-msg") || "");
        if (!modal.open) modal.showModal();
      }
    }

    const confirmBtn = target.closest(".table-delete-confirm");
    if (confirmBtn) {
      const url = confirmBtn.getAttribute("data-url");
      const errorMsg = confirmBtn.getAttribute("data-error-msg") || "Error occurred";
      if (url) {
        fetch(url, { method: "DELETE" }).then((r) => {
          if (r.ok) window.location.reload();
          else alert(errorMsg);
        });
      }
    }
  });
</script>
