---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body style="margin: 0; padding: 0; background-color: #f0f4fa; font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
    <div style="background-color: #f0f4fa; padding: 40px 20px; text-align: center;">
      <div style="max-width: 560px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; border: 1px solid #dce8f7; text-align: left;">
        <!-- Header -->
        <div style="background-color: #00205c; padding: 32px 40px; text-align: center;">
          <slot name="header" />
        </div>
        <!-- Body -->
        <div style="padding: 40px;">
          <slot />
        </div>
        <!-- Footer -->
        <div style="padding: 24px 40px; background-color: #fbfaf7; border-top: 1px solid #f6f4ed; text-align: center;">
          <slot name="footer">
            <p style="margin: 0; color: #8f825e; font-size: 12px; line-height: 1.625;">
               If you did not request this email, you can safely ignore it.
            </p>
          </slot>
        </div>
      </div>
    </div>
  </body>
</html>
