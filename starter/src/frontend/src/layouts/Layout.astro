---
import Sidebar from "../components/Sidebar.astro";
import "../styles/global.css";
import { Image, Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import logo from "../assets/logo.svg";
import { ssr } from "fse-ssr/ssr";

interface Props {
  title: string;
  sidebar?: boolean;
}

const { title, sidebar = true } = Astro.props;
const { lang } = ssr();
---

<!doctype html>
<html lang={lang ?? "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-montserrat" preload />
    <title set:html={title} />
    <!-- Filled by the server with the page's render context as JSON; read it
         client-side via pageProps() from fse-ssr/client. -->
    <script is:inline type="application/json" id="__fse-props__"></script>
    <ClientRouter />
    <script is:inline>
      if (localStorage.getItem("sidebar-mini") === "1") {
        document.documentElement.classList.add("sidebar-mini");
      }
      // Apply the saved (or system) theme before first paint to avoid a flash.
      (function () {
        const saved = localStorage.getItem("theme");
        const dark =
          saved === "dark" ||
          (!saved &&
            window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", dark);
      })();
      document.addEventListener("astro:before-swap", (e) => {
        if (localStorage.getItem("sidebar-mini") === "1") {
          e.newDocument.documentElement.classList.add("sidebar-mini");
        }
        if (document.documentElement.classList.contains("dark")) {
          e.newDocument.documentElement.classList.add("dark");
        }
        // Keep the <Font> @font-face styles/preloads across the head swap so the
        // browser doesn't re-evaluate them and flash a fallback font on the
        // persisted sidebar. See https://github.com/withastro/astro/issues/15465
        for (const head of [document.head, e.newDocument.head]) {
          let i = 0;
          for (const style of head.querySelectorAll("style")) {
            if (style.textContent.includes("@font-face")) {
              style.setAttribute("data-astro-transition-persist", "font-style-" + i++);
            }
          }
          for (const link of head.querySelectorAll('link[rel="preload"][as="font"]')) {
            link.setAttribute(
              "data-astro-transition-persist",
              "font-preload-" + link.getAttribute("href"),
            );
          }
        }
      });
    </script>
  </head>
  <body class="bg-secondary-50">
    <div class="relative flex min-h-screen">
      {sidebar && <Sidebar />}
      <div
        class={`w-full flex flex-col transition-all duration-300 ease-in-out ${sidebar ? "py-6 px-5 lg:py-8 lg:px-8" : ""}`}
      >
        {
          sidebar && (
            <div class="mb-4 flex items-center gap-4">
              <button
                id="open-sidebar"
                class="lg:hidden p-1.5 text-secondary-500 hover:text-secondary-900 hover:bg-secondary-100 transition-colors rounded-lg focus:outline-hidden"
                aria-label="Open menu"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="3" y1="12" x2="21" y2="12" />
                  <line x1="3" y1="6" x2="21" y2="6" />
                  <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
              </button>
              <a href="/" class="lg:hidden">
                <Image src={logo} alt="Logo" class="h-8 w-auto" />
              </a>
            </div>
          )
        }
        <slot />
      </div>
    </div>

    <script>
      function setupLayout() {
        const openBtn = document.getElementById("open-sidebar");
        openBtn?.addEventListener("click", () => {
          document.dispatchEvent(new CustomEvent("open-sidebar"));
        });
      }

      document.addEventListener("astro:page-load", setupLayout);
    </script>
  </body>
</html>
