---
import { ssr } from "fse-ssr/ssr";
import Layout from "../layouts/Layout.astro";

const { t } = ssr();
---

<Layout title={t.common.no_access} sidebar={false}>
  <main class="min-h-screen grid place-items-center bg-secondary-50 px-4">
    <div class="w-full max-w-md text-center flex flex-col items-center gap-5">
      <div class="w-12 h-12 rounded-full bg-secondary-100 border border-secondary-200 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary-500">
          <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <div>
        <h1 class="text-base font-semibold text-secondary-900 mb-1">
          {t.common.no_access}
        </h1>
        <p class="text-sm text-secondary-500">
          {t.common.no_access_desc}
        </p>
      </div>
      <a href="/" class="btn-secondary">
        {t.common.back_home ?? "Back to home"}
      </a>
    </div>
  </main>
</Layout>
