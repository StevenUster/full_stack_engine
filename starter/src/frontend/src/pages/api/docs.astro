---
// Self-hosted Swagger UI for the public API. Everything (JS + CSS) is bundled
// locally via swagger-ui-dist — no external/CDN requests are made. The spec is
// loaded at runtime from our own /api/openapi.json endpoint.
import "swagger-ui-dist/swagger-ui.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>API Docs</title>
    <style>
      body {
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div id="swagger-ui"></div>
    <script>
      import SwaggerUIBundle from "swagger-ui-dist/swagger-ui-es-bundle.js";

      SwaggerUIBundle({
        url: "/api/openapi.json",
        dom_id: "#swagger-ui",
        deepLinking: true,
      });
    </script>
  </body>
</html>
