---
import { ssr } from "fse-ssr/ssr";
import Card from "../../components/Card.astro";
import Input from "../../components/Input.astro";
import ProductTabs from "../../components/ProductTabs.astro";
import Select from "../../components/Select.astro";
import Layout from "../../layouts/Layout.astro";
import type { ProductDetailsManagerPage } from "../../types/pages";

const { t, product, error_slug } = ssr<ProductDetailsManagerPage>();

const statusLabels = t.products.status_options as Record<string, string>;
const statusOptions = [
  { value: "draft", label: statusLabels.draft ?? "Draft" },
  { value: "published", label: statusLabels.published ?? "Published" },
  { value: "archived", label: statusLabels.archived ?? "Archived" },
];
---

<Layout title={product.name}>
  <main class="grid place-items-center">
    <div class="w-full max-w-2xl">
      <ProductTabs
        active="overview"
        backlink="/product-manager"
        name={product.name}
        tabs={[
          { key: "overview", label: t.product_manager.tab_overview ?? "Overview", href: `/product-manager/${product.id}` },
          { key: "orders", label: t.product_manager.tab_orders ?? "Orders", href: `/product-manager/${product.id}/orders` },
        ]}
      />

      <Card>
        <form action={`/product-manager/${product.id}`} method="POST" class="space-y-4">
          <Input id="name" type="text" placeholder={t.products.name ?? "Name"} value={product.name} required />
          <Input id="slug" type="text" placeholder={t.products.slug ?? "Slug"} value={product.slug} />
          <Input id="description" type="text" placeholder={t.products.description ?? "Description"} value={product.description} />
          <Input id="price" type="number" placeholder={t.products.price_label ?? "Price"} value={product.price} step="0.01" min={0} required />
          <Select id="status" placeholder={t.products.status_label ?? "Status"} options={statusOptions} selected={product.status} />

          {
            error_slug === "slug_taken" && (
              <div class="p-4 rounded-xl bg-red-50 border border-red-100">
                <p class="text-sm font-medium text-red-700">
                  {t.products.slug_taken ?? "That slug is already in use."}
                </p>
              </div>
            )
          }

          <button type="submit" class="btn-primary w-full">
            {t.common.save ?? "Save"}
          </button>
        </form>
      </Card>
    </div>
  </main>
</Layout>
