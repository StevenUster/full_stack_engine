---
import { ssr } from "fse-ssr/ssr";
import Card from "../../components/Card.astro";
import Header from "../../components/Header.astro";
import Pagination from "../../components/Pagination.astro";
import Table from "../../components/Table.astro";
import TableFilters from "../../components/TableFilters.astro";
import Layout from "../../layouts/Layout.astro";
import type { ProductManagerPage, TableHeader } from "../../types/pages";

const { t, rows } = ssr<ProductManagerPage>();

const headers: TableHeader[] = [
  { title: "Name", key: "name" },
  { title: "Price", key: "price" },
  { title: "Status", key: "status" },
  { title: "Created", key: "created_at" },
  { title: "Actions", key: "id", format: "delete" },
];
---

<Layout title={t.product_manager.title}>
  <main class="grid place-items-center">
    <div class="w-full">
      <Header action="/product-manager/create" actionLabel={t.product_manager.new ?? "New Product"}>
        {t.product_manager.title}
      </Header>
      <Card padding={false}>
        <TableFilters searchPlaceholder={t.products.search_placeholder ?? "Search products..."} />
        <Table headers={headers} rows={rows} />
        <Pagination />
      </Card>
    </div>
  </main>
</Layout>
