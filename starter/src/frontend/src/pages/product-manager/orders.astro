---
import { ssr } from "fse-ssr/ssr";
import Card from "../../components/Card.astro";
import ProductTabs from "../../components/ProductTabs.astro";
import SearchBar from "../../components/SearchBar.astro";
import Layout from "../../layouts/Layout.astro";
import type { ProductOrdersPage } from "../../types/pages";

const { t, product, rows } = ssr<ProductOrdersPage>();
---

<Layout title={`${product.name} — ${t.product_manager.tab_orders}`}>
  <main class="grid place-items-center">
    <div class="w-full">
      <ProductTabs
        active="orders"
        backlink="/product-manager"
        name={product.name}
        tabs={[
          { key: "overview", label: t.product_manager.tab_overview ?? "Overview", href: `/product-manager/${product.id}` },
          { key: "orders", label: t.product_manager.tab_orders ?? "Orders", href: `/product-manager/${product.id}/orders` },
        ]}
      />

      <Card padding={false}>
        <SearchBar placeholder="Search by customer email..." />

        <div class="w-full overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead class="hidden md:table-header-group">
              <tr class="bg-secondary-50">
                <th class="h-11 px-4 text-xs font-semibold uppercase tracking-wide border-b border-secondary-200 text-secondary-500">Customer</th>
                <th class="h-11 px-4 text-xs font-semibold uppercase tracking-wide border-b border-secondary-200 text-secondary-500">Qty</th>
                <th class="h-11 px-4 text-xs font-semibold uppercase tracking-wide border-b border-secondary-200 text-secondary-500">Note</th>
                <th class="h-11 px-4 text-xs font-semibold uppercase tracking-wide border-b border-secondary-200 text-secondary-500">Status</th>
                <th class="h-11 px-4 text-xs font-semibold uppercase tracking-wide border-b border-secondary-200 text-secondary-500">Actions</th>
              </tr>
            </thead>
            <tbody>
              {
                rows.map((row) => (
                  <tr class="flex flex-col md:table-row border-b border-secondary-100 last:border-b-0 p-4 md:p-0 gap-1.5 md:gap-0">
                    <td class="text-sm px-4 py-2.5 md:border-t border-secondary-100">{row.user_email}</td>
                    <td class="text-sm px-4 py-2.5 md:border-t border-secondary-100">{row.quantity}</td>
                    <td class="text-sm px-4 py-2.5 md:border-t border-secondary-100 text-secondary-500">{row.note}</td>
                    <td class="text-sm px-4 py-2.5 md:border-t border-secondary-100">{row.status}</td>
                    <td class="text-sm px-4 py-2.5 md:border-t border-secondary-100">
                      <div class="flex items-center gap-2">
                        {row.status === "pending" && (
                          <form action={row.fulfill_url} method="POST">
                            <button type="submit" class="btn-secondary">Mark fulfilled</button>
                          </form>
                        )}
                        <form action={row.delete_url} method="POST" data-delete-form>
                          <input type="hidden" name="_method" value="DELETE" />
                          <button type="submit" class="btn-secondary text-red-600 border-red-200 hover:bg-red-50">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </Card>
    </div>
  </main>
</Layout>

<script>
  document.addEventListener("submit", (e) => {
    const form = (e.target as HTMLElement)?.closest("[data-delete-form]") as HTMLFormElement | null;
    if (!form) return;
    e.preventDefault();
    if (!confirm("Delete this order?")) return;
    fetch(form.action, { method: "DELETE" }).then((r) => {
      if (r.ok) window.location.reload();
      else alert("Error occurred");
    });
  });
</script>
