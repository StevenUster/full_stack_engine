---
import { ssr } from "fse-ssr/ssr";
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import Header from "../components/Header.astro";
import Input from "../components/Input.astro";
import Modal from "../components/Modal.astro";
import type { SettingsPage } from "../types/pages";

const {
  t,
  current_email,
  first_name,
  last_name,
  success,
  error,
  email_success,
  email_error,
} = ssr<SettingsPage>();

const messages = t.messages as Record<string, string>;
const errors = t.errors as Record<string, string>;
---

<Layout title={t.settings.title}>
  <main class="max-w-2xl mx-auto">
    <Header>{t.settings.title}</Header>

    <Card>
      <div class="flex flex-col divide-y divide-secondary-100">

        <!-- Name -->
        {(first_name || last_name) && (
        <div class="pb-6">
          <h3 class="text-base font-semibold text-secondary-900">
            {t.settings.name}
          </h3>
          <div class="mt-3 px-4 py-3 rounded-lg bg-secondary-50 border border-secondary-100">
            <span class="text-sm font-medium text-secondary-900">
              {first_name} {last_name}
            </span>
          </div>
        </div>
        )}

        <!-- Email Setting -->
        <div class="py-6 first:pt-0">
          <div class="flex items-start justify-between mb-3 flex-wrap gap-2">
            <div>
              <h3 class="text-base font-semibold text-secondary-900">
                {t.settings.email_address}
              </h3>
              <p class="text-sm text-secondary-500 mt-0.5">
                {t.settings.email_desc}
              </p>
            </div>
            <button type="button" id="change-email-btn" class="btn-secondary shrink-0">
              {t.settings.change_email}
            </button>
          </div>
          <div class="px-4 py-3 rounded-lg bg-secondary-50 border border-secondary-100">
            <span class="text-sm font-medium text-secondary-900">
              {current_email}
            </span>
          </div>
        </div>

        <!-- Password Setting -->
        <div class="py-6">
          <div class="mb-4">
            <h3 class="text-base font-semibold text-secondary-900">
              {t.settings.account_security}
            </h3>
          </div>
          <form action="/settings/password-reset" method="POST" data-astro-reload>
            <button type="submit" class="btn-secondary">
              {t.settings.send_reset}
            </button>
          </form>
          {success && (
            <div class="mt-4 px-4 py-3 rounded-lg bg-primary-50 border border-primary-200">
              <p class="text-sm font-medium text-primary-700">{messages[success] ?? success}</p>
            </div>
          )}
          {error && (
            <div class="mt-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200">
              <p class="text-sm font-medium text-red-700">{errors[error] ?? error}</p>
            </div>
          )}
        </div>

        <!-- Danger Zone -->
        <div class="pt-6">
          <div class="flex items-start justify-between flex-wrap gap-3">
            <div>
              <h3 class="text-base font-semibold text-red-600">
                {t.settings.delete_account}
              </h3>
              <p class="text-sm text-secondary-500 mt-0.5">
                {t.settings.delete_account_desc}
              </p>
            </div>
            <button type="button" id="delete-account-btn" class="btn-danger shrink-0">
              {t.settings.delete_account}
            </button>
          </div>
        </div>

      </div>
    </Card>
  </main>

  <!-- Change Email Modal -->
  <Modal id="change-email-modal" title={t.settings.update_email_title}>
    <form id="change-email-form" action="/settings/change-email" method="POST" data-astro-reload class="flex flex-col gap-5">
      <div class="flex flex-col gap-2">
        <label for="new_email" class="text-sm font-medium text-secondary-700">
          {t.settings.new_email}
        </label>
        <Input id="new_email" type="email" placeholder="e.g. name@example.com" required={true} />
      </div>
      <div class="flex flex-col gap-2">
        <button type="submit" class="w-full btn-primary">
          {t.settings.update_email_btn}
        </button>
        <button type="button" id="cancel-email-change-btn" class="w-full btn-secondary">
          {t.settings.cancel}
        </button>
      </div>
      <div id="modal-messages">
        {email_success && (
          <div class="px-4 py-3 rounded-lg bg-primary-50 border border-primary-200">
            <p class="text-sm font-medium text-primary-700">{messages[email_success] ?? email_success}</p>
          </div>
        )}
        {email_error && (
          <div class="px-4 py-3 rounded-lg bg-red-50 border border-red-200">
            <p class="text-sm font-medium text-red-700">{errors[email_error] ?? email_error}</p>
          </div>
        )}
      </div>
    </form>
  </Modal>

  <!-- Delete Account Modal -->
  <Modal id="delete-account-modal" title={t.settings.delete_account_title}>
    <p class="text-sm text-secondary-600 mb-5">
      {t.settings.delete_account_confirm}
    </p>
    <div class="flex flex-col gap-2">
      <form action="/settings/delete-account" method="POST" data-astro-reload>
        <button type="submit" class="w-full px-4 py-2 inline-flex items-center justify-center text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors">
          {t.settings.delete_account_btn}
        </button>
      </form>
      <button type="button" id="cancel-delete-account-btn" class="w-full btn-secondary">
        {t.settings.cancel}
      </button>
    </div>
  </Modal>

  <script>
    function setupSettings() {
      const modal = document.getElementById("change-email-modal") as HTMLDialogElement;
      const openBtn = document.getElementById("change-email-btn");
      const closeBtn = document.getElementById("cancel-email-change-btn");
      openBtn?.addEventListener("click", () => {
        if (modal && !modal.open) modal.showModal();
      });
      closeBtn?.addEventListener("click", () => modal?.close());

      const messages = document.getElementById("modal-messages");
      if (messages && (messages.textContent?.trim().length ?? 0) > 0 && modal && !modal.open) {
        modal.showModal();
      }

      const deleteAccountModal = document.getElementById("delete-account-modal") as HTMLDialogElement;
      document.getElementById("delete-account-btn")?.addEventListener("click", () => {
        if (deleteAccountModal && !deleteAccountModal.open) deleteAccountModal.showModal();
      });
      document.getElementById("cancel-delete-account-btn")?.addEventListener("click", () => deleteAccountModal?.close());
    }

    // `astro:page-load` replaces DOMContentLoaded, which does not fire on
    // client-side navigation. It also fires on the initial load.
    document.addEventListener("astro:page-load", setupSettings);
  </script>
</Layout>
