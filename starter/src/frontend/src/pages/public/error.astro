---
import { ssr } from "fse-ssr/ssr";
import Card from "../../components/Card.astro";
import Layout from "../../layouts/Layout.astro";

const { t, error } = ssr<{ error?: string }>();
---

<Layout title={t.common.error ?? "Error"} sidebar={false}>
  <main class="grid place-items-center w-full h-screen bg-secondary-50">
    <div class="w-full max-w-md p-4">
      <Card>
        <div class="text-center">
          <h1 class="text-2xl font-bold text-secondary-900 mb-4">
            {t.common.error ?? "Error"}
          </h1>
          <p class="text-red-600 mb-6 font-medium">{error}</p>
          <a href="/" class="btn-primary">
            {t.common.back_home ?? "Back to home"}
          </a>
        </div>
      </Card>
    </div>
  </main>
</Layout>
