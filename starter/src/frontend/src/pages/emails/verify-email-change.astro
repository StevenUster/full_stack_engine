---
import EmailLayout from "../../layouts/EmailLayout.astro";
---

<EmailLayout title="Email Change Verification">
  <h1 slot="header" style="margin: 0; color: #ffffff; font-size: 20px; font-weight: 600; letter-spacing: 0.025em;">
    Confirm Your New Email
  </h1>

  <p style="margin: 0; margin-bottom: 20px; color: #231f16; font-size: 16px; line-height: 1.625;">
    You requested to change your email address. Please confirm your new email
    address by clicking the following button:
  </p>

  <div style="text-align: center; padding-top: 12px; padding-bottom: 28px;">
    <a
      href={"{{ verify_url }}"}
      target="_blank"
      style="display: inline-block; padding: 14px 36px; background-color: #00205c; color: #ffffff; text-decoration: none; font-size: 14px; font-weight: 600; border-radius: 6px; letter-spacing: 0.025em; transition: background-color 0.2s ease-in-out;"
    >
      Confirm New Email
    </a>
  </div>

  <p style="margin: 0; margin-bottom: 12px; color: #6f6345; font-size: 14px; line-height: 1.5;">
    If the button doesn't work, please copy the following link into your
    browser:
  </p>
  <p style="margin: 0; word-break: break-all;">
    <a href={"{{ verify_url }}"} style="color: #528bd9; font-size: 12px; text-decoration: underline;">
      {"{{ verify_url }}"}
    </a>
  </p>

  <p slot="footer" style="margin: 0; color: #8f825e; font-size: 12px; line-height: 1.625;">
    If you did not request this change, you can safely ignore this email. Your email address will not be changed.
  </p>
</EmailLayout>
