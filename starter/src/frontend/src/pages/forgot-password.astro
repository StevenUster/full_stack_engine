---
import Input from "../components/Input.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Forgot Password" sidebar={false}>
  <main class="grid w-screen h-screen place-items-center">
    <form
      class="overflow-hidden w-[400px] bg-white rounded shadow-md text-secondary-500 shadow-secondary-200"
      action="/forgot-password"
      method="POST"
    >
      <div class="p-6">
        <header class="mb-4 text-center">
          <h3 class="text-xl font-medium text-black">
            <Fragment set:html={"{{ t.forgot_password.title }}"} />
          </h3>
        </header>
        <div class="flex flex-col gap-4 mt-12">
          <Input
            id="email"
            type="email"
            placeholder={"{{ t.forgot_password.email_placeholder }}"}
            required={true}
          />
        </div>
      </div>
      <div class="flex justify-end p-6">
        <button
          type="submit"
          class="inline-flex items-center justify-center w-full h-10 gap-2 whitespace-nowrap btn-primary"
        >
          <Fragment set:html={"{{ t.forgot_password.submit }}"} />
        </button>
      </div>
      <div class="pb-6 px-6 text-center">
        <p class="text-sm">
          <a href="/login" class="text-primary-500 hover:underline">
            <Fragment set:html={"{{ t.forgot_password.back_to_login }}"} />
          </a>
        </p>
      </div>
      <Fragment set:html="{% if error %}" />
      <div class="px-6 py-3">
        <div
          class="w-full px-4 py-3 mb-4 text-sm text-pink-500 border border-pink-100 rounded bg-pink-50"
          role="alert"
        >
          <p><Fragment set:html="{{ error }}" /></p>
        </div>
      </div>
      <Fragment set:html="{% endif %}" />
      <Fragment set:html="{% if success %}" />
      <div class="px-6 py-3">
        <div
          class="w-full px-4 py-3 mb-4 text-sm text-green-600 border border-green-100 rounded bg-green-50"
          role="alert"
        >
          <p><Fragment set:html={"{{ t.forgot_password.success }}"} /></p>
        </div>
      </div>
      <Fragment set:html="{% endif %}" />
    </form>
  </main>
</Layout>
