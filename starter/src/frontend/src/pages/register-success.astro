---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Action Required: Verify Email" sidebar={false}>
  <main class="grid w-screen h-screen place-items-center">
    <div class="overflow-hidden w-[400px] bg-white rounded shadow-md text-secondary-500 shadow-secondary-200">
      <div class="p-6">
        <header class="mb-4 text-center">
          <h3 class="text-xl font-medium text-black">Check Your Inbox</h3>
        </header>
        <div class="flex flex-col gap-4 mt-8 text-center text-sm">
          <p>
            You have successfully registered!
          </p>
          <p>
            A confirmation link has been sent to your email address. Please click the link to verify your email before logging in.
          </p>
        </div>
      </div>
      <div class="flex justify-end p-6 border-t border-secondary-100">
        <a href="/login" class="inline-flex items-center justify-center w-full h-10 gap-2 whitespace-nowrap btn-primary">
          <span>Return to Login</span>
        </a>
      </div>
    </div>
  </main>
</Layout>
