---
interface Props {
  icon: "date" | "location" | "distance" | "stages";
}
const { icon } = Astro.props;

const paths: Record<Props["icon"], string> = {
  date: '<rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M16 2v4M8 2v4m-5 4h18"></path>',
  location:
    '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle>',
  distance:
    '<path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"></path><path d="M12 8v4l3 3"></path>',
  stages:
    '<path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48 2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48 2.83-2.83"></path>',
};
---

<div class="flex items-center gap-2 text-sm bg-secondary-50 border border-secondary-100 rounded-lg px-3 py-1.5">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="text-primary-500 shrink-0"
    set:html={paths[icon]}
  />
  <span class="text-secondary-700"><slot /></span>
</div>
