---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<dialog
  id={id}
  class="backdrop:bg-black/60 backdrop:backdrop-blur-sm bg-white rounded-2xl shadow-2xl p-0 w-[95%] max-w-lg overflow-hidden border border-gray-100 transition-all duration-300 ease-out"
>
  <div class="flex items-center justify-between px-8 py-5 border-b border-gray-50 bg-gray-50/50">
    <h3 class="text-xl font-bold text-gray-900 tracking-tight">{title}</h3>
    <button
      type="button"
      class="text-gray-400 hover:text-gray-900 transition-all p-2 rounded-xl hover:bg-white hover:shadow-sm"
      onclick={`document.getElementById('${id}').close()`}
      aria-label="Close modal"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  <div class="p-8">
    <slot />
  </div>
</dialog>

<style>
  dialog::backdrop {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  dialog[open] {
    animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes fadeIn {
    from { opacity: 0; backdrop-filter: blur(0px); }
    to { opacity: 1; backdrop-filter: blur(4px); }
  }

  @keyframes slideUp {
    from { transform: translateY(20px) scale(0.98); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }

  /* Prevent scrolling when dialog is open */
  :global(body:has(dialog[open])) {
    overflow: hidden;
  }
</style>
