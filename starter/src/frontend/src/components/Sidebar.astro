---
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";
import { ssr } from "fse-ssr/ssr";

const { t, user, can_read_products, can_read_users } = ssr<{
  can_read_products?: boolean;
  can_read_users?: boolean;
}>();
---

<div
  id="sidebar-backdrop"
  class="fixed inset-0 z-30 bg-secondary-900/40 backdrop-blur-xs lg:hidden hidden opacity-0 transition-opacity duration-300"
>
</div>

<aside
  id="nav-menu-1"
  aria-label="Side navigation"
  class="fixed lg:sticky top-0 bottom-0 h-dvh left-0 z-40 flex flex-col bg-white border-r border-secondary-200 w-64 transform -translate-x-full lg:translate-x-0 transition-all duration-300 ease-in-out overflow-hidden"
  transition:name="header"
  transition:persist
  transition:animate="none"
>
  <!-- Header -->
  <div
    id="sidebar-header"
    class="relative flex items-center justify-center h-16 shrink-0 px-2"
  >
    <!-- Logo: hidden in mini mode -->
    <a
      aria-label="Logo"
      class="sidebar-full-logo flex items-center gap-2 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-primary-500 rounded-md"
      href="/"
    >
      <Image src={logo} alt="Logo" class="h-12 w-auto" />
    </a>

    <!-- Desktop: minimize toggle -->
    <button
      id="toggle-sidebar-mini"
      class="hidden lg:flex absolute right-2 p-2 text-secondary-500 hover:text-secondary-800 hover:bg-secondary-100 rounded-lg transition-colors focus:outline-hidden"
      aria-label="Toggle sidebar"
    >
      <!-- Collapse icon (visible in full mode) -->
      <svg
        class="sidebar-icon-collapse"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
        <path d="M9 3v18"></path>
        <path d="m16 15-3-3 3-3"></path>
      </svg>
      <!-- Expand icon (visible in mini mode) -->
      <svg
        class="sidebar-icon-expand hidden"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
        <path d="M9 3v18"></path>
        <path d="m14 9 3 3-3 3"></path>
      </svg>
    </button>

    <!-- Mobile: close button -->
    <button
      id="close-sidebar"
      class="lg:hidden absolute right-2 p-2 text-secondary-500 hover:text-secondary-900 hover:bg-secondary-100 rounded-lg transition-colors focus:outline-hidden"
      aria-label="Close sidebar"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Nav -->
  <nav
    aria-label="side navigation"
    class="flex-1 overflow-y-auto px-3 py-3 space-y-0.5"
  >
    <a
      href="/"
      data-nav-link
      class="flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900 aria-[current=page]:bg-primary-50 aria-[current=page]:text-primary-800 aria-[current=page]:font-semibold"
    >
      <svg
        class="shrink-0"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
      >
        <path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M8.557 2.75H4.682A1.93 1.93 0 0 0 2.75 4.682v3.875a1.94 1.94 0 0 0 1.932 1.942h3.875a1.94 1.94 0 0 0 1.942-1.942V4.682A1.94 1.94 0 0 0 8.557 2.75m10.761 0h-3.875a1.94 1.94 0 0 0-1.942 1.932v3.875a1.943 1.943 0 0 0 1.942 1.942h3.875a1.94 1.94 0 0 0 1.932-1.942V4.682a1.93 1.93 0 0 0-1.932-1.932m0 10.75h-3.875a1.94 1.94 0 0 0-1.942 1.933v3.875a1.94 1.94 0 0 0 1.942 1.942h3.875a1.94 1.94 0 0 0 1.932-1.942v-3.875a1.93 1.93 0 0 0-1.932-1.932M8.557 13.5H4.682a1.943 1.943 0 0 0-1.932 1.943v3.875a1.93 1.93 0 0 0 1.932 1.932h3.875a1.94 1.94 0 0 0 1.942-1.932v-3.875a1.94 1.94 0 0 0-1.942-1.942"
        ></path>
      </svg>
      <span class="sidebar-label truncate">
        {t.sidebar.index ?? "Home"}
      </span>
    </a>

    <a
      href="/products"
      data-nav-link
      class="flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900 aria-[current=page]:bg-primary-50 aria-[current=page]:text-primary-800 aria-[current=page]:font-semibold"
    >
      <svg
        class="shrink-0"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
      >
        <g
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
        >
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
          <path d="M16 2v4M8 2v4m-5 4h18"></path>
        </g>
      </svg>
      <span class="sidebar-label truncate">
        {t.sidebar.products ?? "Products"}
      </span>
    </a>

    {user && (
    <a
      href="/my-orders"
      data-nav-link
      class="flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900 aria-[current=page]:bg-primary-50 aria-[current=page]:text-primary-800 aria-[current=page]:font-semibold"
    >
      <svg
        class="shrink-0"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
      <span class="sidebar-label truncate">
        {t.sidebar.my_orders ?? "My Orders"}
      </span>
    </a>
    )}

    {can_read_products && (
    <a
      href="/admin/products"
      data-nav-link
      class="flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900 aria-[current=page]:bg-primary-50 aria-[current=page]:text-primary-800 aria-[current=page]:font-semibold"
    >
      <svg
        class="shrink-0"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
      <span class="sidebar-label truncate">
        {t.sidebar.product_manager ?? "Product Manager"}
      </span>
    </a>
    )}
  </nav>

  <!-- Bottom section -->
  <div class="border-t border-secondary-200 px-3 py-3 space-y-0.5 shrink-0">
    <!-- Theme toggle -->
    <button
      id="toggle-theme"
      type="button"
      class="w-full flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900"
      aria-label="Toggle dark mode"
    >
      <!-- Moon icon (shown in light mode) -->
      <svg
        class="shrink-0 block dark:hidden"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <!-- Sun icon (shown in dark mode) -->
      <svg
        class="shrink-0 hidden dark:block"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
        ></path>
      </svg>
      <span class="sidebar-label truncate">
        <span class="block dark:hidden">
          {t.sidebar.dark_mode ?? "Dark Mode"}
        </span>
        <span class="hidden dark:block">
          {t.sidebar.light_mode ?? "Light Mode"}
        </span>
      </span>
    </button>

    {user ? (
    <>

    {can_read_users && (
    <a
      href="/users"
      data-nav-link
      class="flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900 aria-[current=page]:bg-primary-50 aria-[current=page]:text-primary-800 aria-[current=page]:font-semibold"
    >
      <svg
        class="shrink-0"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
      >
        <g fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="6" r="4"></circle>
          <path
            d="M20 17.5c0 2.485 0 4.5-8 4.5s-8-2.015-8-4.5S7.582 13 12 13s8 2.015 8 4.5Z"
          ></path>
        </g>
      </svg>
      <span class="sidebar-label truncate">
        {t.sidebar.users ?? "Users"}
      </span>
    </a>
    )}

    <a
      href="/settings"
      data-nav-link
      class="flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900 aria-[current=page]:bg-primary-50 aria-[current=page]:text-primary-800 aria-[current=page]:font-semibold"
    >
      <svg
        class="shrink-0"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
      >
        <g
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
        >
          <path
            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
          ></path>
          <circle cx="12" cy="12" r="3"></circle>
        </g>
      </svg>
      <span class="sidebar-label truncate">
        {t.sidebar.settings ?? "Settings"}
      </span>
    </a>

    <form action="/logout" method="POST" data-astro-reload>
      <button
        class="w-full flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900"
        type="submit"
      >
        <svg
          class="shrink-0"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-label="Logout icon"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M11.25 9l-3 3m0 0l3 3m-3-3h7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
        <span class="sidebar-label font-medium truncate">
          {t.sidebar.logout ?? "Logout"}
        </span>
      </button>
    </form>

    </>
    ) : (
    <a
      href="/login"
      class="flex items-center gap-3 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-700 hover:bg-secondary-100 hover:text-secondary-900"
    >
      <svg
        class="shrink-0"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-label="Login icon"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"
        ></path>
      </svg>
      <span class="sidebar-label font-medium truncate">
        {t.sidebar.login ?? "Login"}
      </span>
    </a>
    )}
  </div>
</aside>

<script>
  function setActiveLink() {
    const currentPath = window.location.pathname;
    const links =
      document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
    links.forEach((link) => {
      const href = link.getAttribute("href");
      if (!href) return;
      if (href === "/" && currentPath === "/") {
        link.setAttribute("aria-current", "page");
        return;
      }
      if (href !== "/" && currentPath.startsWith(href)) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  }

  function openSidebar() {
    const sidebar = document.getElementById("nav-menu-1");
    const backdrop = document.getElementById("sidebar-backdrop");
    sidebar?.classList.remove("-translate-x-full");
    backdrop?.classList.remove("hidden");
    setTimeout(() => backdrop?.classList.remove("opacity-0"), 10);
    document.body.style.overflow = "hidden";
  }

  function closeSidebar() {
    const sidebar = document.getElementById("nav-menu-1");
    const backdrop = document.getElementById("sidebar-backdrop");
    sidebar?.classList.add("-translate-x-full");
    backdrop?.classList.add("opacity-0");
    setTimeout(() => backdrop?.classList.add("hidden"), 300);
    document.body.style.overflow = "";
  }

  document.addEventListener("open-sidebar", openSidebar);
  document.addEventListener("close-sidebar", closeSidebar);
  document.addEventListener("astro:before-preparation", closeSidebar);

  function bindOnce(el: HTMLElement | null, type: string, handler: () => void) {
    if (!el || el.dataset.bound === type) return;
    el.dataset.bound = type;
    el.addEventListener("click", handler);
  }

  function setupSidebar() {
    const backdrop = document.getElementById("sidebar-backdrop");
    const closeBtn = document.getElementById("close-sidebar");
    const miniToggle = document.getElementById("toggle-sidebar-mini");
    const root = document.documentElement;

    function syncMiniIcons(isMini: boolean) {
      const collapseIcon = miniToggle?.querySelector(".sidebar-icon-collapse");
      const expandIcon = miniToggle?.querySelector(".sidebar-icon-expand");
      collapseIcon?.classList.toggle("hidden", isMini);
      expandIcon?.classList.toggle("hidden", !isMini);
    }

    syncMiniIcons(root.classList.contains("sidebar-mini"));

    bindOnce(miniToggle, "mini", () => {
      const isMini = root.classList.toggle("sidebar-mini");
      localStorage.setItem("sidebar-mini", isMini ? "1" : "0");
      syncMiniIcons(isMini);
    });
    bindOnce(closeBtn, "close", closeSidebar);
    bindOnce(backdrop, "close", closeSidebar);

    const themeToggle = document.getElementById("toggle-theme");
    bindOnce(themeToggle, "theme", () => {
      const isDark = root.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  }

  document.addEventListener("astro:page-load", () => {
    setActiveLink();
    setupSidebar();
  });
</script>
