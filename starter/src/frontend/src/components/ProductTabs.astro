---
import type { SsrValue } from "fse-ssr/ssr";

// Generic detail-page tab strip: pass whatever tabs your resource needs as a
// prop, each its own SSR route. Astro's ClientRouter makes switching between
// them feel seamless. Copy this pattern for any manageable resource with more
// than one sub-view (e.g. Overview / Orders / Team / Settings).
interface Tab {
  key: string;
  label: string | SsrValue<string>;
  href: string;
}

interface Props {
  tabs: Tab[];
  active: string;
  backlink: string;
  name: string | SsrValue<string>;
}

const { tabs, active, backlink, name } = Astro.props;

const tabClass = (key: string) =>
  `whitespace-nowrap px-1 pb-3 -mb-px text-sm font-medium border-b-2 transition-colors ${
    active === key
      ? "border-primary-500 text-primary-600"
      : "border-transparent text-secondary-500 hover:text-secondary-800 hover:border-secondary-300"
  }`;
---

<div class="flex flex-col gap-5 mb-6">
  <div class="flex items-center gap-2 min-w-0">
    <a
      href={backlink}
      class="p-1.5 text-secondary-500 hover:text-secondary-900 hover:bg-secondary-100 transition-colors rounded-lg shrink-0"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
      >
        <path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M21 12H3m0 0l8.5-8.5M3 12l8.5 8.5"></path>
      </svg>
    </a>
    <h1 class="section-title text-secondary-900 truncate">{name}</h1>
  </div>

  <nav class="flex gap-6 border-b border-secondary-200 overflow-x-auto overflow-y-hidden">
    {
      tabs.map((tab) => (
        <a href={tab.href} class={tabClass(tab.key)}>
          {tab.label}
        </a>
      ))
    }
  </nav>
</div>
