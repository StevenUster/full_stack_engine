RUST_LOG=info

ENV=dev # or prod

DATABASE_URL=sqlite:./data/sqlite.db

DOMAIN=0.0.0.0 # for prod use something like example.com without https
PROTOCOL=http # http or https
PORT=8080

JWT_SECRET=base64_encoded_secret # min 32 chars; generate with `openssl rand -base64 32` (the app refuses to boot with a shorter secret)

# SMTP is needed for password reset and email verification
SMTP_HOST=smtp.example.de:587 # Port 587 is recommended for production
SMTP_PASS=your_smtp_password
SMTP_USER=info@example.de 
EMAIL_VERIFICATION_ENABLED=false # optional

# Optional: site-wide per-IP rate limit applied to every request (DDoS guard).
# Defaults are generous; only set these to tune. Raise for large shared/NAT IPs.
# GLOBAL_RATE_LIMIT_PER_SECOND=100
# GLOBAL_RATE_LIMIT_BURST=500